# Cloudflare Pages headers

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-XSS-Protection: 1; mode=block

# Free tools are embedded on PlotProse/Coral Hart — allow those origins to frame them.
/hook-lab/*
  ! X-Frame-Options
  Content-Security-Policy: frame-ancestors 'self' https://plotprose.com https://www.plotprose.com https://coralhart.com https://www.coralhart.com

/category-checker/*
  ! X-Frame-Options
  Content-Security-Policy: frame-ancestors 'self' https://plotprose.com https://www.plotprose.com https://coralhart.com https://www.coralhart.com

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=300, must-revalidate

/*.css
  Cache-Control: public, max-age=3600, must-revalidate

/*.js
  Cache-Control: public, max-age=3600, must-revalidate
